---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const layersPath = path.join(process.cwd(), 'public', 'layers');
const layerFolders = [
  '1_FONDO',
  '2_BASE',
  '3_ROPA',
  '4_SOMBRERO',
  '5_OJOS',
  '6_BOCA',
  '7_ACCESORIO'
];

const baseColors = [
  "#ffffff", "#fde0d9", "#f5c3b1", "#e8a48c", "#d1866b", "#b0664a", "#8c4a32", "#5e2f1d", 
  "#ffadad", "#ffd6a5", "#fdffb6", "#caffbf", "#9bf6ff", "#a0c4ff", "#bdb2ff", "#ffc6ff",
  "#ff0000", "#ff7f00", "#ffff00", "#00ff00", "#0000ff", "#4b0082", "#9400d3", "#ff1493",
  "#cccccc", "#999999", "#666666", "#333333", "#4a5320", "#191970", "#800000", "#008080" 
];

const bgPatterns = [
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><rect width="10" height="20" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><rect width="20" height="10" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><path d="M-5 5L5 -5M0 20L20 0M15 25L25 15" stroke="_C2_" stroke-width="4"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><path d="M 20 0 L 0 0 0 20" fill="none" stroke="_C2_" stroke-width="2"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><circle cx="10" cy="10" r="5" fill="_C2_"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M0 20 L10 10 L20 20 L30 30 L40 20" fill="none" stroke="_C2_" stroke-width="4"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M 0 20 Q 10 10 20 20 T 40 20" fill="none" stroke="_C2_" stroke-width="4"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><rect width="10" height="10" fill="_C2_"/><rect x="10" y="10" width="10" height="10" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><polygon points="10,0 20,20 0,20" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><polygon points="10,0 20,10 10,20 0,10" fill="_C2_"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M20 5 L24 16 L35 16 L26 23 L29 34 L20 27 L11 34 L14 23 L5 16 L16 16 Z" fill="_C2_"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M0 20H40 M20 0V20 M0 20V40 M40 20V40" stroke="_C2_" stroke-width="2"/></svg>',
  '<svg width="34" height="60" xmlns="http://www.w3.org/2000/svg"><rect width="34" height="60" fill="_C1_"/><path d="M17 0l17 10v20l-17 10-17-10V10z" fill="none" stroke="_C2_" stroke-width="2"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M20 30 Q 10 20 10 12 A 5 5 0 0 1 20 12 A 5 5 0 0 1 30 12 Q 30 20 20 30 Z" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><path d="M10 0V20 M0 10H20" stroke="_C2_" stroke-width="4"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><circle cx="20" cy="20" r="16" fill="none" stroke="_C2_" stroke-width="4"/><circle cx="20" cy="20" r="8" fill="none" stroke="_C2_" stroke-width="4"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><path d="M0 20a20 20 0 0 0 40 0" fill="none" stroke="_C2_" stroke-width="2"/><path d="M-20 40a20 20 0 0 0 40 0 M20 40a20 20 0 0 0 40 0" fill="none" stroke="_C2_" stroke-width="2"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><circle cx="10" cy="10" r="8" fill="none" stroke="_C2_" stroke-width="2"/><circle cx="30" cy="30" r="5" fill="none" stroke="_C2_" stroke-width="2"/></svg>',
  '<svg width="40" height="40" xmlns="http://www.w3.org/2000/svg"><rect width="40" height="40" fill="_C1_"/><rect x="5" y="5" width="5" height="15" transform="rotate(45 7.5 12.5)" fill="_C2_"/><rect x="25" y="20" width="5" height="15" transform="rotate(-30 27.5 27.5)" fill="_C2_"/></svg>',
  '<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="20" fill="_C1_"/><polygon points="0,0 10,0 0,10" fill="_C2_"/><polygon points="10,10 20,10 10,20" fill="_C2_"/><rect x="0" y="10" width="10" height="10" fill="_C2_"/></svg>',
  '<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><rect width="100" height="100" fill="_C1_"/><g fill="none" stroke="_C2_" stroke-width="12" stroke-linecap="round"><path d="M 0 25 Q 25 25 25 0" /><path d="M 0 50 Q 50 50 50 0" /><path d="M 0 75 Q 75 75 75 0" /><path d="M 100 25 Q 75 25 75 100" /><path d="M 100 50 Q 50 50 50 100" /><path d="M 100 75 Q 25 75 25 100" /></g></svg>',
  '<svg width="100" height="100" xmlns="http://www.w3.org/2000/svg"><rect width="100" height="100" fill="_C1_"/><path d="M 0 25 A 25 25 0 0 0 50 25 Z" fill="_C2_" opacity="0.6"/><path d="M 75 0 A 25 25 0 0 0 75 50 Z" fill="_C2_"/><path d="M 25 50 A 25 25 0 0 1 25 100 Z" fill="_C2_"/><path d="M 50 75 A 25 25 0 0 1 100 75 Z" fill="_C2_" opacity="0.6"/></svg>'
];

let availableLayers = [];

try {
  // Ensure directories exist
  if (!fs.existsSync(layersPath)) {
    fs.mkdirSync(layersPath, { recursive: true });
  }
  layerFolders.forEach(folder => {
    const p = path.join(layersPath, folder);
    if (!fs.existsSync(p)) fs.mkdirSync(p, { recursive: true });
  });

  availableLayers = layerFolders.map(folder => {
    const p = path.join(layersPath, folder);
    const files = fs.readdirSync(p).filter(f => f.endsWith('.png') || f.endsWith('.jpg') || f.endsWith('.svg'));
    return {
      id: folder,
      name: folder.replace(/^\d+_/, ''),
      images: files.map(file => `/layers/${folder}/${file}`)
    };
  });
} catch (e) {
  console.error("Error reading layers", e);
}
---

<Layout title="Creador de Personajes">
  <main class="container">
    <header class="header">
      <h1 class="title">Avatar Maker 🎨</h1>
    </header>
    
    <div class="app-layout">
      <!-- Left side: Canvas and preview -->
      <section class="preview-section neo-box">
        <div class="canvas-container">
          <canvas id="avatar-canvas" width="600" height="600"></canvas>
        </div>
        <button id="download-btn" class="neo-button">⬇️ Descargar Avatar</button>
      </section>

      <!-- Right side: Controls -->
      <section class="controls-section neo-box">
        <div class="tabs">
          {availableLayers.map((layer, index) => (
            <button class={`tab-btn ${index === 0 ? 'active' : ''}`} data-target={layer.id}>
              {layer.name}
            </button>
          ))}
        </div>
        
        <div class="tab-contents">
          {availableLayers.map((layer, index) => (
            <div class={`tab-content ${index === 0 ? 'active' : ''}`} id={layer.id}>
              {layer.id.includes('FONDO') && (
                <div class="bg-controls-section">
                  <div class="bg-mode-selector">
                    <label><input type="radio" name="bg-mode" value="image" checked /> Imagen</label>
                    <label><input type="radio" name="bg-mode" value="solid" /> Color Sólido</label>
                    <label><input type="radio" name="bg-mode" value="gradient" /> Degradado</label>
                    <label><input type="radio" name="bg-mode" value="pattern" /> Patrones</label>
                  </div>
                  <div id="pattern-picker" style="display: none;" class="color-picker-section">
                    <div class="transform-controls-section" style="margin-bottom: 1rem;">
                      <h3 class="color-picker-title">Ajustar Patrón</h3>
                      <div class="transform-controls" style="flex-direction: column; align-items: stretch; gap: 10px;">
                        <label style="display: flex; justify-content: space-between; font-size: 14px;">
                          <span>Escala: <span id="pat-scale-val">3</span>x</span>
                          <input type="range" id="pat-scale-input" min="0.5" max="10" step="0.5" value="3" style="width: 60%;" />
                        </label>
                        <label style="display: flex; justify-content: space-between; font-size: 14px;">
                          <span>Rotación: <span id="pat-rot-val">0</span>°</span>
                          <input type="range" id="pat-rot-input" min="-180" max="180" step="5" value="0" style="width: 60%;" />
                        </label>
                      </div>
                    </div>
                    <h3 class="color-picker-title">Elegir Patrón</h3>
                    <div class="pattern-grid">
                      {bgPatterns.map((svg, idx) => (
                        <div class="pattern-item" data-index={idx} style={`background-image: url('data:image/svg+xml;utf8,${encodeURIComponent(svg.replace(/_C1_/g, '#ffffff').replace(/_C2_/g, '#cccccc'))}')`}></div>
                      ))}
                    </div>
                  </div>
                  <div id="pattern-colors-section" style="display: none;" class="color-picker-section">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                      <h3 class="color-picker-title" style="margin-bottom: 0;">Color 1 (Fondo)</h3>
                      <label style="font-size:12px;"><input type="checkbox" id="pat-c1-grad-toggle"> Degradado</label>
                    </div>
                    <div class="color-picker-wrapper" style="margin-top: 10px;">
                      <input type="color" class="neo-color-picker" id="pat-c1a-input" value="#ffffff" />
                      <span class="color-value" id="pat-c1a-val">#ffffff</span>
                    </div>
                    <div id="pat-c1b-container" style="display:none; margin-top:10px;">
                      <h4 style="font-size:12px; margin-bottom:5px; color: var(--text);">Color Final (Degradado)</h4>
                      <div class="color-picker-wrapper">
                        <input type="color" class="neo-color-picker" id="pat-c1b-input" value="#cccccc" />
                        <span class="color-value" id="pat-c1b-val">#cccccc</span>
                      </div>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 20px;">
                      <h3 class="color-picker-title" style="margin-bottom: 0;">Color 2 (Figura)</h3>
                      <label style="font-size:12px;"><input type="checkbox" id="pat-c2-grad-toggle"> Degradado</label>
                    </div>
                    <div class="color-picker-wrapper" style="margin-top: 10px;">
                      <input type="color" class="neo-color-picker" id="pat-c2a-input" value="#cccccc" />
                      <span class="color-value" id="pat-c2a-val">#cccccc</span>
                    </div>
                    <div id="pat-c2b-container" style="display:none; margin-top:10px;">
                      <h4 style="font-size:12px; margin-bottom:5px; color: var(--text);">Color Final (Degradado)</h4>
                      <div class="color-picker-wrapper">
                        <input type="color" class="neo-color-picker" id="pat-c2b-input" value="#333333" />
                        <span class="color-value" id="pat-c2b-val">#333333</span>
                      </div>
                    </div>
                  </div>
                  <div id="solid-color-picker" style="display: none;" class="color-picker-section">
                    <h3 class="color-picker-title">Color 1 (Fondo/Sólido)</h3>
                    <div class="color-picker-wrapper">
                      <input type="color" class="neo-color-picker" id="bg-color1-input" value="#ffffff" />
                      <span class="color-value" id="bg-color1-val">#ffffff</span>
                    </div>
                  </div>
                  <div id="gradient-color-picker" style="display: none;" class="color-picker-section">
                    <h3 class="color-picker-title">Color 2 (Secundario)</h3>
                    <div class="color-picker-wrapper">
                      <input type="color" class="neo-color-picker" id="bg-color2-input" value="#cccccc" />
                      <span class="color-value" id="bg-color2-val">#cccccc</span>
                    </div>
                  </div>
                </div>
              )}
              {layer.id.includes('BASE') && (
                <div class="color-picker-section">
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h3 class="color-picker-title" style="margin-bottom: 0;">Color de Base</h3>
                    <label style="font-size:12px;"><input type="checkbox" id="base-grad-toggle"> Degradado</label>
                  </div>
                  <div class="color-picker-wrapper" style="margin-top: 10px;">
                    <input type="color" class="neo-color-picker" id="base-color-input" value="#ffffff" />
                    <span class="color-value" id="base-color-val">#ffffff</span>
                  </div>
                  <div id="base-color2-container" style="display:none; margin-top:10px;">
                    <h4 style="font-size:12px; margin-bottom:5px; color: var(--text);">Color Final (Degradado)</h4>
                    <div class="color-picker-wrapper">
                      <input type="color" class="neo-color-picker" id="base-color2-input" value="#cccccc" />
                      <span class="color-value" id="base-color2-val">#cccccc</span>
                    </div>
                  </div>
                </div>
              )}
              {layer.id.includes('SOMBRERO') && (
                <div class="transform-controls-section">
                  <h3 class="color-picker-title">Ajustar Sombrero</h3>
                  <div class="transform-controls">
                    <button class="t-btn" id="t-up" title="Arriba">⬆️</button>
                    <button class="t-btn" id="t-down" title="Abajo">⬇️</button>
                    <button class="t-btn" id="t-left" title="Izquierda">⬅️</button>
                    <button class="t-btn" id="t-right" title="Derecha">➡️</button>
                    <button class="t-btn" id="t-rot-left" title="Girar Izquierda">↺</button>
                    <button class="t-btn" id="t-rot-right" title="Girar Derecha">↻</button>
                    <button class="t-btn" id="t-scale-up" title="Agrandar">➕</button>
                    <button class="t-btn" id="t-scale-down" title="Reducir">➖</button>
                    <button class="t-btn" id="t-reset" title="Resetear">🔄</button>
                  </div>
                </div>
              )}
              {layer.id.includes('ACCESORIO') && (
                <div style="margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                  <div class="transform-controls-section" style="margin-bottom: 0;">
                    <h3 class="color-picker-title">Ajustar Accesorio</h3>
                    <div class="transform-controls">
                      <button class="t-btn" id="acc-up" title="Arriba">⬆️</button>
                      <button class="t-btn" id="acc-down" title="Abajo">⬇️</button>
                      <button class="t-btn" id="acc-left" title="Izquierda">⬅️</button>
                      <button class="t-btn" id="acc-right" title="Derecha">➡️</button>
                      <button class="t-btn" id="acc-rot-left" title="Girar Izquierda">↺</button>
                      <button class="t-btn" id="acc-rot-right" title="Girar Derecha">↻</button>
                      <button class="t-btn" id="acc-scale-up" title="Agrandar">➕</button>
                      <button class="t-btn" id="acc-scale-down" title="Reducir">➖</button>
                      <button class="t-btn" id="acc-reset" title="Resetear">🔄</button>
                    </div>
                  </div>
                  <div class="color-picker-section" style="margin-bottom: 0;">
                    <h3 class="color-picker-title">Color de Accesorio</h3>
                    <div class="color-picker-wrapper">
                      <input type="color" class="neo-color-picker" id="acc-color-input" value="#ffffff" />
                      <span class="color-value" id="acc-color-val">#ffffff</span>
                    </div>
                  </div>
                </div>
              )}
              {layer.images.length === 0 ? (
                <p class={`empty-msg ${layer.id.includes('FONDO') ? 'fondo-options-container' : ''}`}>No hay imágenes en la carpeta <code>public/layers/{layer.id}/</code></p>
              ) : (
                <div class={`options-grid ${layer.id.includes('FONDO') ? 'fondo-options-container' : ''}`}>
                  {layer.id.includes('FONDO') && (
                    <div class="option-item upload-option">
                      <label for="bg-upload" class="upload-label">
                        <span style="font-size: 2rem;">📤</span><br/>Subir
                        <input type="file" id="bg-upload" accept="image/*" style="display:none;" />
                      </label>
                    </div>
                  )}
                  <div class="option-item empty-option" data-layer={layer.id} data-image="">
                     <span>Ninguno</span>
                  </div>
                  {layer.images.map(img => (
                    <div class="option-item" data-layer={layer.id} data-image={img}>
                      <img src={img} alt="opcion" loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<script define:vars={{ availableLayers, bgPatterns }}>
  const hexToRgb = (hex) => {
    const num = parseInt(hex.replace('#', ''), 16);
    return {
      r: (num >> 16) & 255,
      g: (num >> 8) & 255,
      b: num & 255
    };
  };

  const interpolateColor = (color1, color2, factor) => {
    const c1 = hexToRgb(color1);
    const c2 = hexToRgb(color2);
    return {
      r: Math.round(c1.r + factor * (c2.r - c1.r)),
      g: Math.round(c1.g + factor * (c2.g - c1.g)),
      b: Math.round(c1.b + factor * (c2.b - c1.b))
    };
  };

  // Initialize state based on available layers
  const state = { baseColor: "#ffffff", baseColor2: "#cccccc", baseMode: "solid", bgMode: "image", bgColor1: "#ffffff", bgColor2: "#cccccc", bgPattern: 0, patternScale: 3, patternRotation: 0, patC1Mode: 'solid', patC1a: '#ffffff', patC1b: '#cccccc', patC2Mode: 'solid', patC2a: '#cccccc', patC2b: '#333333', hatOffsetX: 0, hatOffsetY: 0, hatRotation: 0, hatScale: 1, accOffsetX: 0, accOffsetY: 0, accRotation: 0, accScale: 1, accColor: '#ffffff' };
  availableLayers.forEach(layer => {
    if (layer.id.includes('ACCESORIO')) {
      state[layer.id] = [];
    } else {
      // Select first image by default if available, otherwise empty
      state[layer.id] = layer.images.length > 0 ? layer.images[0] : "";
    }
  });

  const canvas = document.getElementById('avatar-canvas');
  const ctx = canvas.getContext('2d');
  
  // Create an image cache
  const imageCache = {};

  const drawAvatar = async () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    if (state.bgMode === 'solid') {
      ctx.fillStyle = state.bgColor1;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    } else if (state.bgMode === 'gradient') {
      const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
      grad.addColorStop(0, state.bgColor1);
      grad.addColorStop(1, state.bgColor2);
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    } else if (state.bgMode === 'pattern') {
      let defs = '<defs>';
      let c1Val = state.patC1a;
      if (state.patC1Mode === 'gradient') {
        defs += `<linearGradient id="c1g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${state.patC1a}"/><stop offset="100%" stop-color="${state.patC1b}"/></linearGradient>`;
        c1Val = 'url(#c1g)';
      }
      let c2Val = state.patC2a;
      if (state.patC2Mode === 'gradient') {
        defs += `<linearGradient id="c2g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${state.patC2a}"/><stop offset="100%" stop-color="${state.patC2b}"/></linearGradient>`;
        c2Val = 'url(#c2g)';
      }
      defs += '</defs>';

      let svg = bgPatterns[state.bgPattern]
        .replace(/_C1_/g, c1Val)
        .replace(/_C2_/g, c2Val);
      
      // Scale up the SVG natively using state.patternScale to avoid canvas pixelation
      svg = svg.replace(/width="(\d+)"\s+height="(\d+)"/, (match, w, h) => {
        return `width="${parseInt(w) * state.patternScale}" height="${parseInt(h) * state.patternScale}"`;
      }).replace(/(<svg[^>]*>)/, `$1${defs}<g transform="scale(${state.patternScale})">`).replace('</svg>', '</g></svg>');
      
      const svgUrl = `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
      
      if (!imageCache[svgUrl]) {
        await new Promise(resolve => {
          const img = new Image();
          img.src = svgUrl;
          img.onload = () => { imageCache[svgUrl] = img; resolve(); };
          img.onerror = () => resolve();
        });
      }
      
      if (imageCache[svgUrl]) {
        ctx.save();
        ctx.translate(canvas.width / 2, canvas.height / 2);
        ctx.rotate(state.patternRotation * Math.PI / 180);
        
        const diag = Math.sqrt(canvas.width**2 + canvas.height**2);
        ctx.fillStyle = ctx.createPattern(imageCache[svgUrl], 'repeat');
        // We draw a rect large enough to cover the canvas at any rotation, centered
        ctx.fillRect(-diag / 2, -diag / 2, diag, diag);
        ctx.restore();
      }
    }
    
    for (const layer of availableLayers) {
      if (layer.id.includes('FONDO') && state.bgMode !== 'image') continue;
      
      const val = state[layer.id];
      if (!val) continue;
      
      const imgPaths = Array.isArray(val) ? val : [val];
      
      for (const imgPath of imgPaths) {
        if (!imgPath) continue;
        
        if (!imageCache[imgPath]) {
          await new Promise((resolve) => {
            const img = new Image();
            img.src = imgPath;
            img.onload = () => {
              imageCache[imgPath] = img;
              resolve();
            };
            img.onerror = () => resolve(); // Ignore errors
          });
        }
        
        if (imageCache[imgPath]) {
          if (layer.id.includes('BASE') && (state.baseColor !== '#ffffff' || state.baseMode === 'gradient')) {
            const offCanvas = document.createElement('canvas');
            offCanvas.width = canvas.width;
            offCanvas.height = canvas.height;
            const offCtx = offCanvas.getContext('2d');
            
            // Draw original
            offCtx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
            // Solid or Gradient color source-in
            offCtx.globalCompositeOperation = 'source-in';
            if (state.baseMode === 'gradient') {
              // Find the top and bottom non-transparent pixel boundaries of the base image content
              const imgData = offCtx.getImageData(0, 0, offCanvas.width, offCanvas.height);
              const data = imgData.data;
              let minY = 0;
              let maxY = offCanvas.height;
              
              findMinY: for (let y = 0; y < offCanvas.height; y++) {
                for (let x = 0; x < offCanvas.width; x++) {
                  if (data[(y * offCanvas.width + x) * 4 + 3] > 0) {
                    minY = y;
                    break findMinY;
                  }
                }
              }
              findMaxY: for (let y = offCanvas.height - 1; y >= 0; y--) {
                for (let x = 0; x < offCanvas.width; x++) {
                  if (data[(y * offCanvas.width + x) * 4 + 3] > 0) {
                    maxY = y;
                    break findMaxY;
                  }
                }
              }

              const grad = offCtx.createLinearGradient(0, minY, 0, maxY);
              grad.addColorStop(0, state.baseColor);
              grad.addColorStop(1, state.baseColor2);
              offCtx.fillStyle = grad;
            } else {
              offCtx.fillStyle = state.baseColor;
            }
            offCtx.fillRect(0, 0, canvas.width, canvas.height);
            // Multiply by original to restore outlines
            offCtx.globalCompositeOperation = 'multiply';
            offCtx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
            
            ctx.drawImage(offCanvas, 0, 0);
          } else if (layer.id.includes('SOMBRERO')) {
            ctx.save();
            ctx.translate(canvas.width / 2 + state.hatOffsetX, canvas.height / 2 + state.hatOffsetY);
            ctx.rotate(state.hatRotation * Math.PI / 180);
            ctx.scale(state.hatScale, state.hatScale);
            ctx.drawImage(imageCache[imgPath], -canvas.width / 2, -canvas.height / 2, canvas.width, canvas.height);
            ctx.restore();
          } else if (layer.id.includes('ACCESORIO')) {
            ctx.save();
            ctx.translate(canvas.width / 2 + state.accOffsetX, canvas.height / 2 + state.accOffsetY);
            ctx.rotate(state.accRotation * Math.PI / 180);
            ctx.scale(state.accScale, state.accScale);
            
            const accMatch = imgPath.match(/\$([0-9a-fA-F]{6})\./);
            const targetHex = accMatch ? '#' + accMatch[1] : null;
            
            if (targetHex && state.accColor) {
              const offCanvas = document.createElement('canvas');
              offCanvas.width = canvas.width;
              offCanvas.height = canvas.height;
              const offCtx = offCanvas.getContext('2d');
              
              offCtx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
              
              const tRgb = hexToRgb(targetHex);
              const newRgb = hexToRgb(state.accColor);
              
              const imgData = offCtx.getImageData(0, 0, offCanvas.width, offCanvas.height);
              const data = imgData.data;
              const tolerance = 45;

              for (let i = 0; i < data.length; i += 4) {
                if (data[i+3] > 0) {
                  const dr = data[i] - tRgb.r;
                  const dg = data[i+1] - tRgb.g;
                  const db = data[i+2] - tRgb.b;
                  if (Math.abs(dr) < tolerance && Math.abs(dg) < tolerance && Math.abs(db) < tolerance) {
                    data[i] = newRgb.r;
                    data[i+1] = newRgb.g;
                    data[i+2] = newRgb.b;
                  }
                }
              }
              offCtx.putImageData(imgData, 0, 0);
              ctx.drawImage(offCanvas, -canvas.width / 2, -canvas.height / 2, canvas.width, canvas.height);
            } else {
              ctx.drawImage(imageCache[imgPath], -canvas.width / 2, -canvas.height / 2, canvas.width, canvas.height);
            }
            ctx.restore();
          } else {
            ctx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
          }
        }
      }
    }
  };

  // Initial draw
  drawAvatar();

  // Tabs logic
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      
      btn.classList.add('active');
      document.getElementById(btn.dataset.target).classList.add('active');
    });
  });

  // Options logic
  const optionItems = document.querySelectorAll('.option-item');
  
  // Function to update visual selection
  const updateVisualSelection = () => {
    optionItems.forEach(item => {
      const layer = item.dataset.layer;
      const img = item.dataset.image;
      if (layer.includes('ACCESORIO')) {
        if (img === "") {
          if (state[layer].length === 0) item.classList.add('selected');
          else item.classList.remove('selected');
        } else {
          if (state[layer].includes(img)) item.classList.add('selected');
          else item.classList.remove('selected');
        }
      } else {
        if (state[layer] === img) {
          item.classList.add('selected');
        } else {
          item.classList.remove('selected');
        }
      }
    });
  };
  
  updateVisualSelection();

  optionItems.forEach(item => {
    item.addEventListener('click', () => {
      const layer = item.dataset.layer;
      const img = item.dataset.image;
      if (layer.includes('ACCESORIO')) {
        if (img === "") {
          state[layer] = [];
        } else {
          const index = state[layer].indexOf(img);
          if (index > -1) {
            state[layer].splice(index, 1);
          } else {
            state[layer].push(img);
          }
        }
      } else {
        state[layer] = img;
      }
      updateVisualSelection();
      drawAvatar();
    });
  });

  const updateColorSelection = () => {
    // Update inputs and value text blocks
    const baseColorInput = document.getElementById('base-color-input');
    const baseColorVal = document.getElementById('base-color-val');
    if (baseColorInput) baseColorInput.value = state.baseColor;
    if (baseColorVal) baseColorVal.textContent = state.baseColor.toUpperCase();

    const baseColor2Input = document.getElementById('base-color2-input');
    const baseColor2Val = document.getElementById('base-color2-val');
    if (baseColor2Input) baseColor2Input.value = state.baseColor2;
    if (baseColor2Val) baseColor2Val.textContent = state.baseColor2.toUpperCase();

    const accColorInput = document.getElementById('acc-color-input');
    const accColorVal = document.getElementById('acc-color-val');
    if (accColorInput) accColorInput.value = state.accColor;
    if (accColorVal) accColorVal.textContent = state.accColor.toUpperCase();

    const bgColor1Input = document.getElementById('bg-color1-input');
    const bgColor1Val = document.getElementById('bg-color1-val');
    if (bgColor1Input) bgColor1Input.value = state.bgColor1;
    if (bgColor1Val) bgColor1Val.textContent = state.bgColor1.toUpperCase();

    const bgColor2Input = document.getElementById('bg-color2-input');
    const bgColor2Val = document.getElementById('bg-color2-val');
    if (bgColor2Input) bgColor2Input.value = state.bgColor2;
    if (bgColor2Val) bgColor2Val.textContent = state.bgColor2.toUpperCase();

    const patC1aInput = document.getElementById('pat-c1a-input');
    const patC1aVal = document.getElementById('pat-c1a-val');
    if (patC1aInput) patC1aInput.value = state.patC1a;
    if (patC1aVal) patC1aVal.textContent = state.patC1a.toUpperCase();

    const patC1bInput = document.getElementById('pat-c1b-input');
    const patC1bVal = document.getElementById('pat-c1b-val');
    if (patC1bInput) patC1bInput.value = state.patC1b;
    if (patC1bVal) patC1bVal.textContent = state.patC1b.toUpperCase();

    const patC2aInput = document.getElementById('pat-c2a-input');
    const patC2aVal = document.getElementById('pat-c2a-val');
    if (patC2aInput) patC2aInput.value = state.patC2a;
    if (patC2aVal) patC2aVal.textContent = state.patC2a.toUpperCase();

    const patC2bInput = document.getElementById('pat-c2b-input');
    const patC2bVal = document.getElementById('pat-c2b-val');
    if (patC2bInput) patC2bInput.value = state.patC2b;
    if (patC2bVal) patC2bVal.textContent = state.patC2b.toUpperCase();
    
    // Update pattern previews
    let defs = '<defs>';
    let c1Val = state.patC1a;
    if (state.patC1Mode === 'gradient') {
      defs += `<linearGradient id="c1g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${state.patC1a}"/><stop offset="100%" stop-color="${state.patC1b}"/></linearGradient>`;
      c1Val = 'url(#c1g)';
    }
    let c2Val = state.patC2a;
    if (state.patC2Mode === 'gradient') {
      defs += `<linearGradient id="c2g" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${state.patC2a}"/><stop offset="100%" stop-color="${state.patC2b}"/></linearGradient>`;
      c2Val = 'url(#c2g)';
    }
    defs += '</defs>';

    document.querySelectorAll('.pattern-item').forEach((item, idx) => {
      let svg = bgPatterns[idx].replace(/_C1_/g, c1Val).replace(/_C2_/g, c2Val);
      svg = svg.replace(/(<svg[^>]*>)/, `$1${defs}`);
      item.style.backgroundImage = `url('data:image/svg+xml;utf8,${encodeURIComponent(svg)}')`;
      if (idx === state.bgPattern) item.classList.add('selected');
      else item.classList.remove('selected');
    });
  };
  
  updateColorSelection();

  // Pattern clicks
  document.querySelectorAll('.pattern-item').forEach(item => {
    item.addEventListener('click', () => { state.bgPattern = parseInt(item.dataset.index); updateColorSelection(); drawAvatar(); });
  });

  const setupColorInput = (id, stateKey) => {
    const input = document.getElementById(id);
    if (input) {
      input.addEventListener('input', (e) => {
        state[stateKey] = e.target.value;
        updateColorSelection();
        drawAvatar();
      });
    }
  };

  setupColorInput('base-color-input', 'baseColor');
  setupColorInput('base-color2-input', 'baseColor2');
  setupColorInput('bg-color1-input', 'bgColor1');
  setupColorInput('bg-color2-input', 'bgColor2');
  setupColorInput('pat-c1a-input', 'patC1a');
  setupColorInput('pat-c1b-input', 'patC1b');
  setupColorInput('pat-c2a-input', 'patC2a');
  setupColorInput('pat-c2b-input', 'patC2b');
  const baseGradToggle = document.getElementById('base-grad-toggle');
  const baseColor2Container = document.getElementById('base-color2-container');
  if (baseGradToggle) {
    baseGradToggle.addEventListener('change', (e) => {
      state.baseMode = e.target.checked ? 'gradient' : 'solid';
      if (baseColor2Container) baseColor2Container.style.display = e.target.checked ? 'block' : 'none';
      updateColorSelection();
      drawAvatar();
    });
  }
  const c1GradToggle = document.getElementById('pat-c1-grad-toggle');
  const c1bContainer = document.getElementById('pat-c1b-container');
  if (c1GradToggle) {
    c1GradToggle.addEventListener('change', (e) => {
      state.patC1Mode = e.target.checked ? 'gradient' : 'solid';
      c1bContainer.style.display = e.target.checked ? 'block' : 'none';
      updateColorSelection();
      drawAvatar();
    });
  }
  const c2GradToggle = document.getElementById('pat-c2-grad-toggle');
  const c2bContainer = document.getElementById('pat-c2b-container');
  if (c2GradToggle) {
    c2GradToggle.addEventListener('change', (e) => {
      state.patC2Mode = e.target.checked ? 'gradient' : 'solid';
      c2bContainer.style.display = e.target.checked ? 'block' : 'none';
      updateColorSelection();
      drawAvatar();
    });
  }

  const bgRadios = document.querySelectorAll('input[name="bg-mode"]');
  const fondoOptions = document.querySelectorAll('.fondo-options-container');
  const solidPicker = document.getElementById('solid-color-picker');
  const gradientPicker = document.getElementById('gradient-color-picker');
  const patternPicker = document.getElementById('pattern-picker');
  const patternColorsSection = document.getElementById('pattern-colors-section');
  
  const patScaleInput = document.getElementById('pat-scale-input');
  const patRotInput = document.getElementById('pat-rot-input');
  const patScaleVal = document.getElementById('pat-scale-val');
  const patRotVal = document.getElementById('pat-rot-val');

  if (patScaleInput) {
    patScaleInput.addEventListener('input', (e) => {
      state.patternScale = parseFloat(e.target.value);
      patScaleVal.textContent = state.patternScale;
      drawAvatar();
    });
  }
  if (patRotInput) {
    patRotInput.addEventListener('input', (e) => {
      state.patternRotation = parseInt(e.target.value);
      patRotVal.textContent = state.patternRotation;
      drawAvatar();
    });
  }
  
  bgRadios.forEach(r => {
    r.addEventListener('change', (e) => {
      state.bgMode = e.target.value;
      
      fondoOptions.forEach(el => el.style.display = 'none');
      if (solidPicker) solidPicker.style.display = 'none';
      if (gradientPicker) gradientPicker.style.display = 'none';
      if (patternPicker) patternPicker.style.display = 'none';
      if (patternColorsSection) patternColorsSection.style.display = 'none';

      if (state.bgMode === 'image') {
        fondoOptions.forEach(el => el.style.display = '');
      } else if (state.bgMode === 'solid') {
        if (solidPicker) solidPicker.style.display = 'block';
      } else if (state.bgMode === 'gradient') {
        if (solidPicker) solidPicker.style.display = 'block';
        if (gradientPicker) gradientPicker.style.display = 'block';
      } else if (state.bgMode === 'pattern') {
        if (patternPicker) patternPicker.style.display = 'block';
        if (patternColorsSection) patternColorsSection.style.display = 'block';
      }
      drawAvatar();
    });
  });

  // Upload background image logic
  const bgUpload = document.getElementById('bg-upload');
  if (bgUpload) {
    bgUpload.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (event) => {
          const dataUrl = event.target.result;
          const layerId = availableLayers.find(l => l.id.includes('FONDO'))?.id;
          if (layerId) {
            state[layerId] = dataUrl;
            updateVisualSelection();
            drawAvatar();
          }
        };
        reader.readAsDataURL(file);
      }
    });
  }

  const moveStep = 10;
  const rotStep = 5;

  document.getElementById('t-up')?.addEventListener('click', () => { state.hatOffsetY -= moveStep; drawAvatar(); });
  document.getElementById('t-down')?.addEventListener('click', () => { state.hatOffsetY += moveStep; drawAvatar(); });
  document.getElementById('t-left')?.addEventListener('click', () => { state.hatOffsetX -= moveStep; drawAvatar(); });
  document.getElementById('t-right')?.addEventListener('click', () => { state.hatOffsetX += moveStep; drawAvatar(); });
  document.getElementById('t-rot-left')?.addEventListener('click', () => { state.hatRotation -= rotStep; drawAvatar(); });
  document.getElementById('t-rot-right')?.addEventListener('click', () => { state.hatRotation += rotStep; drawAvatar(); });
  const scaleStep = 0.05;
  document.getElementById('t-scale-up')?.addEventListener('click', () => { state.hatScale += scaleStep; drawAvatar(); });
  document.getElementById('t-scale-down')?.addEventListener('click', () => { state.hatScale = Math.max(0.1, state.hatScale - scaleStep); drawAvatar(); });
  document.getElementById('t-reset')?.addEventListener('click', () => { 
    state.hatOffsetX = 0; 
    state.hatOffsetY = 0; 
    state.hatRotation = 0; 
    state.hatScale = 1;
    drawAvatar(); 
  });

  setupColorInput('acc-color-input', 'accColor');

  const accMoveStep = 10;
  const accRotStep = 5;
  const accScaleStep = 0.05;

  document.getElementById('acc-up')?.addEventListener('click', () => { state.accOffsetY -= accMoveStep; drawAvatar(); });
  document.getElementById('acc-down')?.addEventListener('click', () => { state.accOffsetY += accMoveStep; drawAvatar(); });
  document.getElementById('acc-left')?.addEventListener('click', () => { state.accOffsetX -= accMoveStep; drawAvatar(); });
  document.getElementById('acc-right')?.addEventListener('click', () => { state.accOffsetX += accMoveStep; drawAvatar(); });
  document.getElementById('acc-rot-left')?.addEventListener('click', () => { state.accRotation -= accRotStep; drawAvatar(); });
  document.getElementById('acc-rot-right')?.addEventListener('click', () => { state.accRotation += accRotStep; drawAvatar(); });
  document.getElementById('acc-scale-up')?.addEventListener('click', () => { state.accScale += accScaleStep; drawAvatar(); });
  document.getElementById('acc-scale-down')?.addEventListener('click', () => { state.accScale = Math.max(0.1, state.accScale - accScaleStep); drawAvatar(); });
  document.getElementById('acc-reset')?.addEventListener('click', () => { 
    state.accOffsetX = 0; 
    state.accOffsetY = 0; 
    state.accRotation = 0; 
    state.accScale = 1;
    drawAvatar(); 
  });

  // Download logic
  const downloadBtn = document.getElementById('download-btn');
  downloadBtn.addEventListener('click', () => {
    const link = document.createElement('a');
    link.download = `avatar_${Date.now()}.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
  });
</script>

