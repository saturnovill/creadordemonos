---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const layersPath = path.join(process.cwd(), 'public', 'layers');
const layerFolders = [
  '1_FONDO',
  '2_BASE',
  '3_ROPA',
  '4_SOMBRERO',
  '5_OJOS',
  '6_BOCA',
  '7_ACCESORIO'
];

const baseColors = [
  "#ffffff", "#fde0d9", "#f5c3b1", "#e8a48c", "#d1866b", "#b0664a", "#8c4a32", "#5e2f1d", 
  "#ffadad", "#ffd6a5", "#fdffb6", "#caffbf", "#9bf6ff", "#a0c4ff", "#bdb2ff", "#ffc6ff",
  "#ff0000", "#ff7f00", "#ffff00", "#00ff00", "#0000ff", "#4b0082", "#9400d3", "#ff1493",
  "#cccccc", "#999999", "#666666", "#333333", "#4a5320", "#191970", "#800000", "#008080" 
];

let availableLayers = [];

try {
  // Ensure directories exist
  if (!fs.existsSync(layersPath)) {
    fs.mkdirSync(layersPath, { recursive: true });
  }
  layerFolders.forEach(folder => {
    const p = path.join(layersPath, folder);
    if (!fs.existsSync(p)) fs.mkdirSync(p, { recursive: true });
  });

  availableLayers = layerFolders.map(folder => {
    const p = path.join(layersPath, folder);
    const files = fs.readdirSync(p).filter(f => f.endsWith('.png') || f.endsWith('.jpg') || f.endsWith('.svg'));
    return {
      id: folder,
      name: folder.replace(/^\d+_/, ''),
      images: files.map(file => `/layers/${folder}/${file}`)
    };
  });
} catch (e) {
  console.error("Error reading layers", e);
}
---

<Layout title="Creador de Personajes">
  <main class="container">
    <header class="header">
      <h1 class="title">Avatar Maker 🎨</h1>
    </header>
    
    <div class="app-layout">
      <!-- Left side: Canvas and preview -->
      <section class="preview-section neo-box">
        <div class="canvas-container">
          <canvas id="avatar-canvas" width="600" height="600"></canvas>
        </div>
        <button id="download-btn" class="neo-button">⬇️ Descargar Avatar</button>
      </section>

      <!-- Right side: Controls -->
      <section class="controls-section neo-box">
        <div class="tabs">
          {availableLayers.map((layer, index) => (
            <button class={`tab-btn ${index === 0 ? 'active' : ''}`} data-target={layer.id}>
              {layer.name}
            </button>
          ))}
        </div>
        
        <div class="tab-contents">
          {availableLayers.map((layer, index) => (
            <div class={`tab-content ${index === 0 ? 'active' : ''}`} id={layer.id}>
              {layer.id.includes('FONDO') && (
                <div class="bg-controls-section">
                  <div class="bg-mode-selector">
                    <label><input type="radio" name="bg-mode" value="image" checked /> Imagen</label>
                    <label><input type="radio" name="bg-mode" value="solid" /> Color Sólido</label>
                    <label><input type="radio" name="bg-mode" value="gradient" /> Degradado</label>
                  </div>
                  <div id="solid-color-picker" style="display: none;" class="color-picker-section">
                    <h3 class="color-picker-title">Color de Fondo 1</h3>
                    <div class="color-grid">
                      {baseColors.map(color => (
                        <div class="color-swatch bg-swatch-1" data-color={color} style={`background-color: ${color}`}></div>
                      ))}
                    </div>
                  </div>
                  <div id="gradient-color-picker" style="display: none;" class="color-picker-section">
                    <h3 class="color-picker-title">Color de Fondo 2 (Degradado)</h3>
                    <div class="color-grid">
                      {baseColors.map(color => (
                        <div class="color-swatch bg-swatch-2" data-color={color} style={`background-color: ${color}`}></div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
              {layer.id.includes('BASE') && (
                <div class="color-picker-section">
                  <h3 class="color-picker-title">Color de Base</h3>
                  <div class="color-grid">
                    {baseColors.map(color => (
                      <div class="color-swatch base-swatch" data-color={color} style={`background-color: ${color}`}></div>
                    ))}
                  </div>
                </div>
              )}
              {layer.id.includes('SOMBRERO') && (
                <div class="transform-controls-section">
                  <h3 class="color-picker-title">Ajustar Sombrero</h3>
                  <div class="transform-controls">
                    <button class="t-btn" id="t-up" title="Arriba">⬆️</button>
                    <button class="t-btn" id="t-down" title="Abajo">⬇️</button>
                    <button class="t-btn" id="t-left" title="Izquierda">⬅️</button>
                    <button class="t-btn" id="t-right" title="Derecha">➡️</button>
                    <button class="t-btn" id="t-rot-left" title="Girar Izquierda">↺</button>
                    <button class="t-btn" id="t-rot-right" title="Girar Derecha">↻</button>
                    <button class="t-btn" id="t-reset" title="Resetear">🔄</button>
                  </div>
                </div>
              )}
              {layer.images.length === 0 ? (
                <p class={`empty-msg ${layer.id.includes('FONDO') ? 'fondo-options-container' : ''}`}>No hay imágenes en la carpeta <code>public/layers/{layer.id}/</code></p>
              ) : (
                <div class={`options-grid ${layer.id.includes('FONDO') ? 'fondo-options-container' : ''}`}>
                  <div class="option-item empty-option" data-layer={layer.id} data-image="">
                     <span>Ninguno</span>
                  </div>
                  {layer.images.map(img => (
                    <div class="option-item" data-layer={layer.id} data-image={img}>
                      <img src={img} alt="opcion" loading="lazy" />
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<script define:vars={{ availableLayers }}>
  // Initialize state based on available layers
  const state = { baseColor: "#ffffff", bgMode: "image", bgColor1: "#ffffff", bgColor2: "#cccccc", hatOffsetX: 0, hatOffsetY: 0, hatRotation: 0 };
  availableLayers.forEach(layer => {
    // Select first image by default if available, otherwise empty
    state[layer.id] = layer.images.length > 0 ? layer.images[0] : "";
  });

  const canvas = document.getElementById('avatar-canvas');
  const ctx = canvas.getContext('2d');
  
  // Create an image cache
  const imageCache = {};

  const drawAvatar = async () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    if (state.bgMode === 'solid') {
      ctx.fillStyle = state.bgColor1;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    } else if (state.bgMode === 'gradient') {
      const grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
      grad.addColorStop(0, state.bgColor1);
      grad.addColorStop(1, state.bgColor2);
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }
    
    for (const layer of availableLayers) {
      if (layer.id.includes('FONDO') && state.bgMode !== 'image') continue;
      
      const imgPath = state[layer.id];
      if (imgPath) {
        if (!imageCache[imgPath]) {
          await new Promise((resolve) => {
            const img = new Image();
            img.src = imgPath;
            img.onload = () => {
              imageCache[imgPath] = img;
              resolve();
            };
            img.onerror = () => resolve(); // Ignore errors
          });
        }
        
        if (imageCache[imgPath]) {
          if (layer.id.includes('BASE') && state.baseColor !== '#ffffff') {
            const offCanvas = document.createElement('canvas');
            offCanvas.width = canvas.width;
            offCanvas.height = canvas.height;
            const offCtx = offCanvas.getContext('2d');
            
            // Draw original
            offCtx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
            // Solid color source-in
            offCtx.globalCompositeOperation = 'source-in';
            offCtx.fillStyle = state.baseColor;
            offCtx.fillRect(0, 0, canvas.width, canvas.height);
            // Multiply by original to restore outlines
            offCtx.globalCompositeOperation = 'multiply';
            offCtx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
            
            ctx.drawImage(offCanvas, 0, 0);
          } else if (layer.id.includes('SOMBRERO')) {
            ctx.save();
            ctx.translate(canvas.width / 2 + state.hatOffsetX, canvas.height / 2 + state.hatOffsetY);
            ctx.rotate(state.hatRotation * Math.PI / 180);
            ctx.drawImage(imageCache[imgPath], -canvas.width / 2, -canvas.height / 2, canvas.width, canvas.height);
            ctx.restore();
          } else {
            ctx.drawImage(imageCache[imgPath], 0, 0, canvas.width, canvas.height);
          }
        }
      }
    }
  };

  // Initial draw
  drawAvatar();

  // Tabs logic
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => b.classList.remove('active'));
      tabContents.forEach(c => c.classList.remove('active'));
      
      btn.classList.add('active');
      document.getElementById(btn.dataset.target).classList.add('active');
    });
  });

  // Options logic
  const optionItems = document.querySelectorAll('.option-item');
  
  // Function to update visual selection
  const updateVisualSelection = () => {
    optionItems.forEach(item => {
      const layer = item.dataset.layer;
      const img = item.dataset.image;
      if (state[layer] === img) {
        item.classList.add('selected');
      } else {
        item.classList.remove('selected');
      }
    });
  };
  
  updateVisualSelection();

  optionItems.forEach(item => {
    item.addEventListener('click', () => {
      const layer = item.dataset.layer;
      const img = item.dataset.image;
      state[layer] = img;
      updateVisualSelection();
      drawAvatar();
    });
  });

  const updateColorSelection = () => {
    document.querySelectorAll('.base-swatch').forEach(swatch => {
      if (swatch.dataset.color === state.baseColor) swatch.classList.add('selected');
      else swatch.classList.remove('selected');
    });
    document.querySelectorAll('.bg-swatch-1').forEach(swatch => {
      if (swatch.dataset.color === state.bgColor1) swatch.classList.add('selected');
      else swatch.classList.remove('selected');
    });
    document.querySelectorAll('.bg-swatch-2').forEach(swatch => {
      if (swatch.dataset.color === state.bgColor2) swatch.classList.add('selected');
      else swatch.classList.remove('selected');
    });
  };
  
  updateColorSelection();

  document.querySelectorAll('.base-swatch').forEach(swatch => {
    swatch.addEventListener('click', () => { state.baseColor = swatch.dataset.color; updateColorSelection(); drawAvatar(); });
  });
  document.querySelectorAll('.bg-swatch-1').forEach(swatch => {
    swatch.addEventListener('click', () => { state.bgColor1 = swatch.dataset.color; updateColorSelection(); drawAvatar(); });
  });
  document.querySelectorAll('.bg-swatch-2').forEach(swatch => {
    swatch.addEventListener('click', () => { state.bgColor2 = swatch.dataset.color; updateColorSelection(); drawAvatar(); });
  });

  const bgRadios = document.querySelectorAll('input[name="bg-mode"]');
  const fondoOptions = document.querySelectorAll('.fondo-options-container');
  const solidPicker = document.getElementById('solid-color-picker');
  const gradientPicker = document.getElementById('gradient-color-picker');
  
  bgRadios.forEach(r => {
    r.addEventListener('change', (e) => {
      state.bgMode = e.target.value;
      if (state.bgMode === 'image') {
        fondoOptions.forEach(el => el.style.display = '');
        solidPicker.style.display = 'none';
        gradientPicker.style.display = 'none';
      } else if (state.bgMode === 'solid') {
        fondoOptions.forEach(el => el.style.display = 'none');
        solidPicker.style.display = 'block';
        gradientPicker.style.display = 'none';
      } else if (state.bgMode === 'gradient') {
        fondoOptions.forEach(el => el.style.display = 'none');
        solidPicker.style.display = 'block';
        gradientPicker.style.display = 'block';
      }
      drawAvatar();
    });
  });

  const moveStep = 10;
  const rotStep = 5;

  document.getElementById('t-up')?.addEventListener('click', () => { state.hatOffsetY -= moveStep; drawAvatar(); });
  document.getElementById('t-down')?.addEventListener('click', () => { state.hatOffsetY += moveStep; drawAvatar(); });
  document.getElementById('t-left')?.addEventListener('click', () => { state.hatOffsetX -= moveStep; drawAvatar(); });
  document.getElementById('t-right')?.addEventListener('click', () => { state.hatOffsetX += moveStep; drawAvatar(); });
  document.getElementById('t-rot-left')?.addEventListener('click', () => { state.hatRotation -= rotStep; drawAvatar(); });
  document.getElementById('t-rot-right')?.addEventListener('click', () => { state.hatRotation += rotStep; drawAvatar(); });
  document.getElementById('t-reset')?.addEventListener('click', () => { 
    state.hatOffsetX = 0; 
    state.hatOffsetY = 0; 
    state.hatRotation = 0; 
    drawAvatar(); 
  });

  // Download logic
  const downloadBtn = document.getElementById('download-btn');
  downloadBtn.addEventListener('click', () => {
    const link = document.createElement('a');
    link.download = `avatar_${Date.now()}.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
  });
</script>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .header {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .title {
    font-size: 3rem;
    color: var(--surface);
    text-shadow: 3px 3px 0px var(--border), -1px -1px 0px var(--border), 1px -1px 0px var(--border), -1px 1px 0px var(--border), 1px 1px 0px var(--border);
    letter-spacing: 2px;
  }
  
  .app-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  
  @media (max-width: 768px) {
    .app-layout {
      flex-direction: column;
    }
    .preview-section {
      position: sticky;
      top: 1rem;
      padding: 1rem;
      z-index: 10;
      gap: 1rem;
    }
    .canvas-container {
      max-width: 200px;
    }
    .controls-section {
      padding: 1rem;
      min-height: auto;
      width: 100%;
    }
    .container {
      padding: 0.5rem;
    }
    .title {
      font-size: 2rem;
      margin-bottom: 1rem;
    }
    .tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.5rem;
      margin-bottom: 1rem;
    }
    .tabs::-webkit-scrollbar {
      height: 6px;
    }
    .tabs::-webkit-scrollbar-thumb {
      background-color: var(--border);
      border-radius: 3px;
    }
    .tab-btn {
      flex-shrink: 0;
      font-size: 0.9rem;
      padding: 6px 12px;
    }
    .options-grid {
      grid-template-columns: repeat(auto-fill, minmax(70px, 1fr));
      gap: 0.5rem;
    }
    .neo-button {
      padding: 8px 16px;
      font-size: 1rem;
    }
  }
  
  .preview-section {
    flex: 1;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    position: sticky;
    top: 2rem;
  }
  
  .canvas-container {
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1/1;
    background: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABQAAAAUCAYAAACNiR0NAAAAMElEQVQ4T2NkYOD4z8ABYIwMjAxUB8AATsBqGJ9gHDWMMQz+j8Cjho0aRihYnAwEACi7Qwm75F2wAAAAAElFTkSuQmCC') repeat;
    border: 3px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  
  canvas {
    width: 100%;
    height: 100%;
    display: block;
    background-color: transparent;
  }
  
  .controls-section {
    flex: 1.5;
    padding: 2rem;
    min-height: 600px;
  }
  
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 3px solid var(--border);
    padding-bottom: 1rem;
  }
  
  .tab-btn {
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 8px 16px;
    font-family: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .tab-btn:hover {
    background: #f3f4f6;
  }
  
  .tab-btn.active {
    background: var(--primary);
    color: white;
    box-shadow: 3px 3px 0px var(--border);
    transform: translateY(-2px);
  }
  
  .tab-content {
    display: none;
  }
  
  .tab-content.active {
    display: block;
  }
  
  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 1rem;
  }
  
  .option-item {
    aspect-ratio: 1/1;
    border: 2px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    overflow: hidden;
    background: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
