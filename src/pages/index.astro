    border-color: var(--primary);
    border-width: 4px;
    box-shadow: 4px 4px 0px var(--primary);
  }
  
  .option-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABQAAAAUCAYAAACNiR0NAAAAMElEQVQ4T2NkYOD4z8ABYIwMjAxUB8AATsBqGJ9gHDWMMQz+j8Cjho0aRihYnAwEACi7Qwm75F2wAAAAAElFTkSuQmCC') repeat;
  }
  
  .empty-option {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    font-weight: bold;
    color: #6b7280;
  }
  
  .empty-msg {
    text-align: center;
    color: #6b7280;
    font-style: italic;
    padding: 2rem;
  }
  
  .color-picker-section {
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f8fafc;
    border: 2px solid var(--border);
    border-radius: 12px;
  }
  .color-picker-title {
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(30px, 1fr));
    gap: 8px;
  }
  .color-swatch {
    aspect-ratio: 1/1;
    border-radius: 6px;
    border: 2px solid var(--border);
    cursor: pointer;
    transition: transform 0.1s;
  }
  .color-swatch:hover {
    transform: scale(1.1);
  }
  .color-swatch.selected {
    border: 3px solid var(--primary);
    box-shadow: 0 0 0 2px var(--surface), 0 0 0 4px var(--primary);
  }
  
  .bg-controls-section {
    margin-bottom: 1rem;
  }
  
  .bg-mode-selector {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    padding: 1rem;
    background: #f8fafc;
    border: 2px solid var(--border);
    border-radius: 12px;
  }
  
  .bg-mode-selector label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-weight: bold;
  }
  
  .transform-controls-section {
    margin-bottom: 1rem;
    padding: 1rem;
    background: #f8fafc;
    border: 2px solid var(--border);
    border-radius: 12px;
  }
  .transform-controls {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .t-btn {
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 1.2rem;
    cursor: pointer;
    box-shadow: 2px 2px 0px var(--border);
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .t-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 0px 0px 0px var(--border);
  }
  .t-btn:hover {
    background: #f3f4f6;
  }
</style>
